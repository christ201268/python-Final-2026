def process_transaction(customer, item_name, proposed_price, inventory_df):
    # Check if item exists and quantity > 0
    if item_name not in inventory_df.index:
        return False, 0, f"Failure: {item_name} not found in inventory."
    if inventory_df.loc[item_name, 'quantity'] <= 0:
        return False, 0, f"Failure: {item_name} is out of stock."

    item_base_cost = inventory_df.loc[item_name, 'base_cost']

    # Calculate customer's 'max bid'
    # Max bid is based on loyalty score and cannot exceed their budget.
    customer_max_bid = item_base_cost * customer.loyalty_score

    # Make sure max_bid doesn't exceed customer's current budget
    effective_max_bid = min(customer_max_bid, customer.budget)

    # Determine if the transaction is successful
    if proposed_price <= effective_max_bid:
        # Transaction successful
        inventory_df.loc[item_name, 'quantity'] -= 1
        customer.loyalty_score = min(2.0, customer.loyalty_score + 0.1) # Increase loyalty, max 2.0
        customer.budget -= proposed_price
        return True, proposed_price, f"Success: {item_name} sold to {customer.name} for ${proposed_price:,.2f}."
    else:
        # Transaction failed
        customer.loyalty_score = max(0.5, customer.loyalty_score - 0.05) # Decrease loyalty, min 0.5
        if proposed_price > customer.budget:
            return False, 0, f"Failure: {customer.name} cannot afford {item_name}. Proposed price ${proposed_price:,.2f} was too high for their budget (${customer.budget:,.2f})."
        else: # proposed_price > customer_max_bid
            return False, 0, f"Failure: {customer.name} rejected {item_name}. Proposed price ${proposed_price:,.2f} was too high (Max bid: ${effective_max_bid:,.2f})."

session_log = []

# Keep track of initial loyalty scores for later analysis
initial_loyalty = {customer.name: customer.loyalty_score for customer in customers}

# Store initial quantities of all items to calculate stock depletion
initial_inventory_quantities = inventory_df['quantity'].copy()

for turn in range(20):
    # Randomly select a customer and an item
    customer = random.choice(customers)
    item_name = random.choice(inventory_df.index.tolist())

    # Choose a pricing strategy that allows for sales initially
    if item_name in inventory_df.index:
        base_cost = inventory_df.loc[item_name, 'base_cost']
        # New pricing strategy: Randomly propose a price between 80% of base_cost and 100% of base_cost.
        # This ensures that with an initial loyalty of 1.0, the max bid is met or exceeded, allowing sales.
        proposed_price = base_cost * random.uniform(0.8, 1.0)
    else:
        # If item_name somehow isn't in index (shouldn't happen with random.choice from index.tolist())
        # Skip this turn or handle appropriately
        continue

    # Execute transaction and append results to session_log list
    success, price, message = process_transaction(customer, item_name, proposed_price, inventory_df)

    session_log.append({
        'turn': turn + 1,
        'customer_name': customer.name,
        'item_name': item_name,
        'proposed_price': proposed_price,
        'final_price': price, # This will be 0 if transaction failed
        'success': success,
        'message': message,
        'customer_budget_after': customer.budget,
        'customer_loyalty_after': customer.loyalty_score
    })

# After the loop, create results_df = pd.DataFrame(session_log)
results_df = pd.DataFrame(session_log)

print("--- Simulation Results ---")
display(results_df.head())
display(inventory_df.head())

# Store final loyalty scores for later analysis
final_loyalty = {customer.name: customer.loyalty_score for customer in customers}

# --- PRINT YOUR FINAL REPORT ---
print("\n--- Merchant Performance Analytics ---")

# 1. Total Revenue: Sum of all successful transaction prices.
total_revenue = results_df[results_df['success'] == True]['final_price'].sum()
print(f"1. Total Revenue: ${total_revenue:,.2f}")

# 2. Potential Revenue: Sum of all proposed prices (even failed ones).
potential_revenue = results_df['proposed_price'].sum()
print(f"2. Potential Revenue (if all sold): ${potential_revenue:,.2f}")

# 3. Success Rate: Percentage of attempts that were successful.
success_rate = results_df['success'].mean() * 100 if not results_df.empty else 0
print(f"3. Transaction Success Rate: {success_rate:.2f}%")

# Prepare successful_trades DataFrame for further calculations
successful_trades = results_df[results_df['success'] == True].copy()

# 4. Avg Markup: The average difference between base cost and sold price.
# Merge with original inventory_df to get base_cost for successful trades
successful_trades['item_base_cost'] = successful_trades['item_name'].map(inventory_df['base_cost'])
# Ensure we only calculate markup if there were successful trades
if not successful_trades.empty:
    successful_trades['markup'] = successful_trades['final_price'] - successful_trades['item_base_cost']
    avg_markup = successful_trades['markup'].mean()
    print(f"4. Average Markup on Successful Trades: ${avg_markup:,.2f}")
else:
    print("4. Average Markup on Successful Trades: $0.00 (No successful trades)")

# 5. Revenue Leakage: Total money lost from successful trades where you sold below base cost.
if not successful_trades.empty:
    revenue_leakage = (successful_trades[successful_trades['final_price'] < successful_trades['item_base_cost']]['item_base_cost'] -
                       successful_trades['final_price']).sum()
    print(f"5. Revenue Leakage (sold below base cost): ${revenue_leakage:,.2f}")
else:
    print("5. Revenue Leakage (sold below base cost): $0.00")


# 6. Customer Retention: How many customers made more than 1 successful trade?
successful_sales_per_customer = results_df[results_df['success'] == True].groupby('customer_name').size()
retained_customers = (successful_sales_per_customer > 1).sum()
print(f"6. Customers with >1 Successful Trade: {retained_customers}")

# 7. Loyalty Trend: The average change in loyalty scores from start to finish.
loyalty_changes = []
for name in initial_loyalty:
    loyalty_changes.append(final_loyalty[name] - initial_loyalty[name])
avg_loyalty_change = pd.Series(loyalty_changes).mean()
print(f"7. Average Loyalty Change: {avg_loyalty_change:.2f}")

# 8. Most Profitable Item: Which item generated the most total revenue?
if not successful_trades.empty:
    item_revenue = successful_trades.groupby('item_name')['final_price'].sum()
    most_profitable_item = item_revenue.idxmax()
    most_profitable_item_revenue = item_revenue.max()
    print(f"8. Most Profitable Item: {most_profitable_item} (Revenue: ${most_profitable_item_revenue:,.2f})")
else:
    print("8. Most Profitable Item: N/A (No successful trades)")

# 9. Stock Depletion: What percentage of your total starting stock was sold?
total_initial_stock = initial_inventory_quantities.sum()
total_final_stock = inventory_df['quantity'].sum()
stock_sold = total_initial_stock - total_final_stock
stock_depletion_percentage = (stock_sold / total_initial_stock) * 100 if total_initial_stock > 0 else 0
print(f"9. Stock Depletion: {stock_depletion_percentage:.2f}%")

# 10. Top Category: Which item category (weapon, food, etc.) had the most successful trades?
if not successful_trades.empty:
    # Map categories back using the original inventory_df (base_cost and category columns are static)
    successful_trades['category'] = successful_trades['item_name'].map(inventory_df['category'])
    top_category = successful_trades['category'].value_counts().idxmax()
    top_category_count = successful_trades['category'].value_counts().max()
    print(f"10. Top Category (by successful trades): {top_category} ({top_category_count} trades)")
else:
    print("10. Top Category: N/A (No successful trades)")

#11. Most Profitable Cateory: Which category generated the most total revenue?
if not successful_trades.empty:
    category_revenue = successful_trades.groupby('category')['final_price'].sum()
    most_profitable_category = category_revenue.idxmax()
    most_profitable_category_revenue = category_revenue.max()
    print(f"11. Most Profitable Category: {most_profitable_category} (Revenue: ${most_profitable_category_revenue:,.2f})")
else:
    print("11. Most Profitable Category: N/A (No successful trades)")



