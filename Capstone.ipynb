class Customer:
    def __init__(self, name):
        # Validate name
        if not isinstance(name, str) or not name.strip():
            raise ValueError("Name must be a non-empty string.")
        self.name = name
        self.budget = self._generate_budget()
        if 'inventory_df' in globals() and not inventory_df.empty:
            self.category_preference = random.choice(inventory_df['category'].unique().tolist())
        else:
            self.category_preference = random.choice(['electronics', 'medical', 'energy', 'tool', 'security'])

        self.loyalty_score = 1.0

    def _generate_budget(self):
        """Generate a budget with weighted probability."""
        roll = random.random()  # Value between 0.0 and 1.0

        if roll < 0.800:  # 80% chance
            return random.randint(20, 1000)
        elif roll < 0.950:  # Next 15% chance
            return random.randint(1000, 15000)
        else:  # Last 5% chance
            return random.randint(15000, 1000000000 )

    def __repr__(self):
        """Return a string with the customer's details for easy printing."""
        return f"Customer(Name: {self.name}, Budget: ${self.budget:,.2f}, Preference: {self.category_preference}, Loyalty: {self.loyalty_score:.2f})"

